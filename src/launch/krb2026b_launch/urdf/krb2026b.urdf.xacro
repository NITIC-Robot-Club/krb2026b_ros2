<?xml version="1.0"?>
<robot name="swerve_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ==================== -->
  <!-- Parameters           -->
  <!-- ==================== -->
  <xacro:property name="wheel_radius" value="0.0375"/>
  <xacro:property name="wheel_width"  value="0.02"/>

  <material name="white">
    <color rgba="1.000 1.000 1.000 1.0"/>
  </material>

  <!-- ==================== -->
  <!-- Base link             -->
  <!-- ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://krb2026b_launch/meshes/base_link.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- ==================== -->
  <!-- Wheel module macro    -->
  <!-- ==================== -->
  <xacro:macro name="swerve" params="wheel_base_name wheel_name x y">

    <!-- steer link -->
    <link name="${wheel_base_name}_link">
      <visual>
        <origin xyz="0 0 0.14" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://krb2026b_launch/meshes/wheel.stl"/>
        </geometry>
        <material name="white"/>
      </visual>
    </link>

    <!-- steer joint -->
    <joint name="${wheel_base_name}" type="continuous">
      <parent link="base_link"/>
      <child link="${wheel_base_name}_link"/>
      <origin xyz="${x} ${y} ${wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>

    <!-- as5600 link -->
    <link name="${wheel_base_name}_as5600_link"/>

    <!-- as5600 joint -->
    <joint name="${wheel_base_name}_as5600" type="continuous">
      <parent link="base_link"/>
      <child link="${wheel_base_name}_as5600_link"/>
      <origin xyz="${x} ${y} 0.16" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>

    <!-- wheel link -->
    <link name="${wheel_name}_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin rpy="1.5708 0 0"/>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <!-- wheel joint -->
    <joint name="${wheel_name}" type="continuous">
      <parent link="${wheel_base_name}_link"/>
      <child link="${wheel_name}_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

  <!-- ==================== -->
  <!-- Wheel instances       -->
  <!-- ==================== -->
  <xacro:swerve wheel_base_name="swerve_wheel_base_0" wheel_name="swerve_wheel_0" x="0.173"  y="0.173"/>
  <xacro:swerve wheel_base_name="swerve_wheel_base_1" wheel_name="swerve_wheel_1" x="-0.173" y="0.173"/>
  <xacro:swerve wheel_base_name="swerve_wheel_base_2" wheel_name="swerve_wheel_2" x="-0.173" y="-0.173"/>
  <xacro:swerve wheel_base_name="swerve_wheel_base_3" wheel_name="swerve_wheel_3" x="0.173"  y="-0.173"/>

  <!-- ==================== -->
  <!-- Lidar frames         -->
  <!-- ==================== -->
  <link name="lidar_right"/>
  <joint name="base_link_to_lidar_right" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_right"/>
    <origin xyz="0.0 -0.184 0" rpy="0 0 -1.5708"/>
  </joint>

  <link name="lidar_left"/>
  <joint name="base_link_to_lidar_left" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_left"/>
    <origin xyz="0.0 0.184 0" rpy="0 0 1.5708"/>
  </joint>


  <link name="lidar_rear"/>
  <joint name="base_link_to_lidar_rear" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_rear"/>
    <origin xyz="-0.288 -0.07 0.1" rpy="0 0 3.1415926535"/>
  </joint>

  <joint name="belt_launcher" type="continuous">
    <origin xyz="-0.15555731148 0.0 0.18967226953" rpy="0.0 -0.43633231299 0.0"/>
    <axis xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="belt_launcher_link"/>
  </joint>

  <link name="belt_launcher_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://krb2026b_launch/meshes/belt_launcher.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="collector_arm_left" type="revolute">
    <origin xyz="-0.052075 0.233296 0.193222" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="collector_arm_left_link"/>
    <limit lower="-3.14159" upper="3.14159" effort="0" velocity="0"/>
  </joint>

  <link name="collector_arm_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://krb2026b_launch/meshes/collector_arm_left.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="collector_hand_left" type="revolute">
    <origin xyz="-0.149379 0.02 0.028125" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 0 -1"/>
    <parent link="collector_arm_left_link"/>
    <child link="collector_hand_left_link"/>
    <limit lower="-3.14159" upper="3.14159" effort="0" velocity="0"/>
  </joint>

  <link name="collector_hand_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://krb2026b_launch/meshes/collector_hand_left.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="collector_arm_right" type="revolute">
    <origin xyz="-0.052075 -0.233296 0.193222" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="collector_arm_right_link"/>
    <limit lower="-3.14159" upper="3.14159" effort="0" velocity="0"/>
  </joint>

  <link name="collector_arm_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://krb2026b_launch/meshes/collector_arm_right.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="collector_hand_right" type="revolute">
    <origin xyz="-0.149379 -0.02 0.028125" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 0 1"/>
    <parent link="collector_arm_right_link"/>
    <child link="collector_hand_right_link"/>
    <limit lower="-3.14159" upper="3.14159" effort="0" velocity="0"/>
  </joint>

  <link name="collector_hand_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://krb2026b_launch/meshes/collector_hand_right.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

</robot>