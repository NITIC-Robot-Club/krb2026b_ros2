<launch>
    <arg name="launch_simulation" default="false"/>
    <arg name="publish_map" default="true"/>
    <arg name="launch_localization" default="true"/>
    <arg name="use_laserscan_convert" default="true"/>
    <arg name="use_ransac" default="true"/>
    <arg name="use_odom_tf" default="false"/>
    <arg name="occupancy_grid_resolution" default="0.02"/>
    <arg name="merged_lidar_publish_frequency" default="30.0"/>
    <arg name="initial_allow_auto_drive" default="true"/>

    <arg name="urdf_path" default="$(find-pkg-share krb2026b_launch)/urdf/krb2026b.urdf.xacro"/>
    <arg name="chassis_param_path" default="$(find-pkg-share krb2026b_launch)/config/robot.yaml"/>
    <arg name="line_segments_path" default="$(find-pkg-share krb2026b_launch)/map/line_segments.csv"/>
    <arg name="circles_path" default="$(find-pkg-share krb2026b_launch)/map/circles.csv"/>
    <arg name="footprint_param_path" default="$(find-pkg-share krb2026b_launch)/config/robot.yaml"/>
    <arg name="lidar_param_path" default="$(find-pkg-share krb2026b_launch)/config/lidar.yaml"/>
    <arg name="localization_param_path" default="$(find-pkg-share krb2026b_launch)/param/localization.yaml"/>
    <arg name="planning_param_path" default="$(find-pkg-share krb2026b_launch)/param/planning.yaml"/>
    <arg name="control_param_path" default="$(find-pkg-share krb2026b_launch)/param/control.yaml"/>
    <arg name="controller_param_path" default="$(find-pkg-share krb2026b_launch)/config/controller.yaml"/>
    <arg name="simulation_param_path" default="$(find-pkg-share krb2026b_launch)/param/simulation.yaml"/>
    <arg name="state_graph_path" default=""/>

    <arg name="joint_state_topics" default="['/swerve/command_joint_states', '/controller/joint_states', '/behavior/command_joint_states', '/test/command_joint_states']"/>

    <include file="$(find-pkg-share natto_launch)/launch/natto.launch.xml">
        <arg name="urdf_path" value="$(var urdf_path)"/>
        <arg name="chassis_type" value="swerve"/>
        <arg name="use_odom_tf" value="$(var use_odom_tf)"/>
        <arg name="initial_allow_auto_drive" value="$(var initial_allow_auto_drive)"/>
        <arg name="launch_simulation" value="$(var launch_simulation)"/>
        <arg name="publish_map" value="$(var publish_map)"/>
        <arg name="launch_localization" value="$(var launch_localization)"/>
        <arg name="use_laserscan_convert" value="$(var use_laserscan_convert)"/>
        <arg name="use_ransac" value="$(var use_ransac)"/>
        <arg name="occupancy_grid_resolution" value="$(var occupancy_grid_resolution)"/>
        <arg name="merged_lidar_publish_frequency" value="$(var merged_lidar_publish_frequency)"/>
        <arg name="chassis_param_path" value="$(var chassis_param_path)"/>
        <arg name="line_segments_path" value="$(var line_segments_path)"/>
        <arg name="circles_path" value="$(var circles_path)"/>
        <arg name="footprint_param_path" value="$(var footprint_param_path)"/>
        <arg name="lidar_param_path" value="$(var lidar_param_path)"/>
        <arg name="localization_param_path" value="$(var localization_param_path)"/>
        <arg name="planning_param_path" value="$(var planning_param_path)"/>
        <arg name="control_param_path" value="$(var control_param_path)"/>
        <arg name="controller_param_path" value="$(var controller_param_path)"/>
        <arg name="simulation_param_path" value="$(var simulation_param_path)"/>
        <arg name="state_graph_path" value="$(var state_graph_path)"/>
        <arg name="state_timeout_sec" value="3.0"/>
        <arg name="joint_state_topics" value="$(var joint_state_topics)"/>
    </include>
</launch>