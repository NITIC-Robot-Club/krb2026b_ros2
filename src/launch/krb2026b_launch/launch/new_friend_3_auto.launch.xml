<launch>

    <include file="$(find-pkg-share krb2026b_launch)/launch/real.launch.xml">
        <arg name="use_joy_control" value="false"/>
        <arg name="launch_common" value="false"/>
        <arg name="launch_localization" value="false"/>
    </include>

    <node pkg="nav2_map_server" exec="map_server" name="map_server" output="screen"
        args="--ros-args -p yaml_filename:=$(find-pkg-share krb2026b_launch)/map/new_friend_3/map.yaml">
        <remap from="map" to="/common/occupancy_grid"/>
    </node>
    <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager" name="lifecycle_manager_map" output="screen"
        args="--ros-args
            -p autostart:=true
            -p node_names:=['map_server']"/>

    <node_container name="dual_laser_merger_container" namespace="" pkg="rclcpp_components" exec="component_container" output="screen">
        <composable_node pkg="dual_laser_merger" plugin="merger_node::MergerNode" name="dual_laser_merger">
            <param name="laser_1_topic" value="/sensing/lidar/laserscan/front"/>
            <param name="laser_2_topic" value="/sensing/lidar/laserscan/rear"/>
            <param name="merged_scan_topic" value="/sensing/lidar/laserscan/merged"/>
            <param name="publish_rate" value="100"/>
            <param name="scan_time" value="0.032894108444452286"/>
            <param name="target_frame" value="base_link"/>
            <param name="angle_min" value="-3.141592654"/>
            <param name="angle_max" value="3.141592654"/>
            <param name="angle_increment" value="0.002181661564992912"/>
            <param name="range_min" value="0.1"/>
            <param name="range_max" value="30.0"/>
            <param name="min_height" value="-1.0"/>
            <param name="max_height" value="1.0"/>
            <param name="use_inf" value="false"/>
        </composable_node>
    </node_container>


    <node pkg="emcl2" exec="emcl2_node"  args="--ros-args --log-level WARN">
        <param from="$(find-pkg-share krb2026b_launch)/param/emcl2.yaml"/>
        <remap from="scan" to="/sensing/lidar/laserscan/merged"/>
        <remap from="map" to="/common/occupancy_grid"/>
        <remap from="mcl_pose" to="/localization/current_pose"/>
    </node>

</launch>