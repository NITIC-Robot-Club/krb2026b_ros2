<launch>
    <include file="$(find-pkg-share krb2026b_launch)/launch/real.launch.xml">
        <arg name="use_joy_control" value="true"/>
        <arg name="launch_common" value="false"/>
        <arg name="launch_localization" value="true"/>
        <!-- <arg name="line_segments_path" value="$(find-pkg-share krb2026b_launch)/map/new_friend_3/line_segments.csv"/> -->
        <arg name="use_odom_tf" value="true"/>
    </include>

    <node pkg="natto_visualization_converter" exec="footprint_publisher" name="footprint_publisher" namespace="/common">
        <param from="$(var footprint_param_path)"/>
    </node>
    
    <node pkg="nav2_map_server" exec="map_server" name="map_server" output="screen"
        args="--ros-args -p yaml_filename:=/home/kazu/map.yaml">
        <remap from="map" to="/common/occupancy_grid"/>
    </node>
    <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager" name="lifecycle_manager_map" output="screen"
        args="--ros-args
            -p autostart:=true
            -p node_names:=['map_server']"/>
    
</launch>