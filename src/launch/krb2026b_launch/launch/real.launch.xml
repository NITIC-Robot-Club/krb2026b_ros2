<launch>
    <arg name="publish_map" default="true"/>
    <arg name="launch_localization" default="true"/>
    <arg name="use_odom_tf" default="false"/>
    <arg name="launch_behavior" default="true"/>
    <arg name="line_segments_path" default="$(find-pkg-share krb2026b_launch)/map/line_segments.csv"/>
    <arg name="launch_simulation" default="false"/>
    <arg name="launch_sensing" default="false"/>
    <arg name="initial_allow_auto_drive" default="true"/>
    <!-- <arg name="state_graph_path" default="$(find-pkg-share krb2026b_launch)/state_graph/real.md"/> -->
    <arg name="state_graph_path" default="$(find-pkg-share krb2026b_launch)/state_graph/duck_detect.md"/>

    <include file="$(find-pkg-share krb2026b_launch)/launch/krb2026b.launch.xml"/>

    <node_container pkg="rclcpp_components" exec="component_container" name="can_container" namespace="/can">
        <composable_node pkg="natto_canable" plugin="canable::canable" name="canable">
            <param name="use_fd" value="true"/>
            <remap from="transmit" to="/can/transmit"/>
            <remap from="receive" to="/can/receive"/>
        </composable_node>
        <composable_node pkg="natto_can_bridge" plugin="can_bridge::can_bridge" name="can_bridge">
            <param from="$(find-pkg-share krb2026b_launch)/config/can.yaml"/>
            <remap from="transmit" to="/can/transmit"/>
            <remap from="receive" to="/can/receive"/>
            <remap from="power" to="/controller/power"/>
        </composable_node>
    </node_container>
    
    <include file="$(find-pkg-share krb2026b_launch)/launch/sensing.launch.xml"/>
</launch>