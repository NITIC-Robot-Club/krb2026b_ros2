<launch>
    <node_container pkg="rclcpp_components" exec="component_container" name="detection_container" namespace="/detection">
        <!-- bottle detection -->
        <composable_node pkg="krb2026b_bottle_detection" plugin="bottle_detection::bottle_detection" name="bottle_detection" namespace="/detection">
            <remap from="laserscan" to="/sensing/lidar/laserscan/rear"/>
            <param name="cluster_dist_thresh" value="0.3"/>
            <param name="cluster_min_pts" value="5"/>
        </composable_node>

        <!-- bottle collector -->
        <composable_node pkg="krb2026b_behavior" plugin="bottle_collector::bottle_collector" name="bottle_collector" namespace="/behavior">
            <remap from="path" to="/planning/path"/>
            <remap from="bottle_pairs" to="/detection/bottle_pairs"/>
            <remap from="goal_reached" to="/control/static/goal_reached"/>
            <param name="offset_normal_m" value="0.3"/>
            <param name="offset_large_m" value="0.4"/>
            <param name="min_start_velocity_mps" value="0.1"/>
        </composable_node>
    </node_container>
</launch>