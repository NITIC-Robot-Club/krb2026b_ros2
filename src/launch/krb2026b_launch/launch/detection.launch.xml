<launch>
    <arg name="model_path" default="$(find-pkg-share krb2026b_launch)/model/best_int8_openvino_model/best.xml"/>
    <arg name="detection_param_path" default="$(find-pkg-share krb2026b_launch)/param/detection.yaml"/>

    <node_container pkg="rclcpp_components" exec="component_container" name="detection_container" namespace="/detection">
        <!-- bottle detection -->
        <composable_node pkg="krb2026b_bottle_detection" plugin="bottle_detection::bottle_detection" name="bottle_detection" namespace="/detection">
            <remap from="laserscan" to="/sensing/lidar/laserscan/rear"/>
            <param from="$(var detection_param_path)"/>
            <param name="reverse_y" value="$(var reverse_y)"/>
            <param name="reverse_y_offset" value="$(var reverse_y_offset)"/>
        </composable_node>

        <!-- bottle collector -->
        <composable_node pkg="krb2026b_behavior" plugin="bottle_collector::bottle_collector" name="bottle_collector" namespace="/behavior">
            <remap from="path" to="/planning/path"/>
            <remap from="bottle_pairs" to="/detection/bottle_pairs"/>
            <remap from="goal_reached" to="/control/dynamic/goal_reached"/>
            <param from="$(var detection_param_path)"/>
        </composable_node>

        <composable_node pkg="krb2026b_duck_detection" plugin="duck_detection::duck_detection" name="duck_detection" namespace="/detection">
            <param name="model_path" value="$(var model_path)"/>
            <remap from="color_image_raw" to="/sensing/camera/color/image_raw"/>
            <remap from="aligned_depth_to_color_image_raw" to="/sensing/camera/aligned_depth_to_color/image_raw"/>
            <remap from="camera_info" to="/sensing/camera/color/camera_info"/>
        </composable_node>

        <composable_node pkg="krb2026b_behavior" plugin="duck_collector::duck_collector" name="duck_collector" namespace="/behavior">
            <remap from="goal_reached" to="/control/dynamic/goal_reached"/>
            <param name="x_offset" value="-0.9"/>
            <param name="y_offset" value="0.05"/>
            <param name="filter_gain" value="0.5"/>
            <param name="goal_dist_threshold" value="0.1"/>
        </composable_node>
    </node_container>

</launch>