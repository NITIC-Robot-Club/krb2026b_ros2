<?xml version="1.0"?>
<launch>
    <node_container pkg="rclcpp_components" exec="component_container" name="sensing_container" namespace="/sensing/lidar">
        <!-- rear -->
        <composable_node pkg="lakibeam1" plugin="lakibeam1::lakibeam1_scan" name="lidar_rear_driver" namespace="/sensing/lidar">
            <remap from="rear" to="/sensing/lidar/laserscan/rear_raw" />
            <param from="$(find-pkg-share krb2026b_launch)/config/lidar_rear.yaml"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>
        
        <composable_node pkg="natto_laser_filter" plugin="laser_filter::laser_filter" name="laserscan_filter_rear" namespace="/sensing/lidar">
            <remap from="input" to="/sensing/lidar/laserscan/rear_raw"/>
            <remap from="output" to="/sensing/lidar/laserscan/rear"/>
            <param from="$(find-pkg-share krb2026b_launch)/config/lidar_rear.yaml"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>

        <composable_node pkg="natto_lidar_converter" plugin="pointcloud2_merger::pointcloud2_merger" name="converter_rear" namespace="/sensing/lidar">
            <remap from="input" to="/sensing/lidar/laserscan/rear"/>
            <remap from="output" to="/sensing/lidar/pointcloud2/rear"/>
            <param from="$(find-pkg-share krb2026b_launch)/config/lidar_rear.yaml"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>

        <!-- right -->
        <composable_node pkg="urg_node2_nl" plugin="urg_node2_nl::UrgNode2NL" name="lidar_right_driver" namespace="/sensing/lidar">
            <remap from="scan" to="/sensing/lidar/laserscan/right_raw"/>
            <param from="$(find-pkg-share krb2026b_launch)/config/lidar_right.yaml"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>
        
        <composable_node pkg="natto_laser_filter" plugin="laser_filter::laser_filter" name="laserscan_filter_right" namespace="/sensing/lidar">
            <remap from="input" to="/sensing/lidar/laserscan/right_raw"/>
            <remap from="output" to="/sensing/lidar/laserscan/right"/>
            <param from="$(find-pkg-share krb2026b_launch)/config/lidar_right.yaml"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>

        <composable_node pkg="natto_lidar_converter" plugin="pointcloud2_merger::pointcloud2_merger" name="converter_right" namespace="/sensing/lidar">
            <remap from="input" to="/sensing/lidar/laserscan/right"/>
            <remap from="output" to="/sensing/lidar/pointcloud2/right"/>
            <param from="$(find-pkg-share krb2026b_launch)/config/lidar_right.yaml"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>

        <!-- left -->
        <composable_node pkg="urg_node2_nl" plugin="urg_node2_nl::UrgNode2NL" name="lidar_left_driver" namespace="/sensing/lidar">
            <remap from="scan" to="/sensing/lidar/laserscan/left_raw"/>
            <param from="$(find-pkg-share krb2026b_launch)/config/lidar_left.yaml"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>
        
        <composable_node pkg="natto_laser_filter" plugin="laser_filter::laser_filter" name="laserscan_filter_left" namespace="/sensing/lidar">
            <remap from="input" to="/sensing/lidar/laserscan/left_raw"/>
            <remap from="output" to="/sensing/lidar/laserscan/left"/>
            <param from="$(find-pkg-share krb2026b_launch)/config/lidar_left.yaml"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>

        <composable_node pkg="natto_lidar_converter" plugin="pointcloud2_merger::pointcloud2_merger" name="converter_left" namespace="/sensing/lidar">
            <remap from="input" to="/sensing/lidar/laserscan/left"/>
            <remap from="output" to="/sensing/lidar/pointcloud2/left"/>
            <param from="$(find-pkg-share krb2026b_launch)/config/lidar_left.yaml"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>

        <!-- merger -->
        <composable_node pkg="natto_lidar_merger" plugin="pointcloud2_merger::pointcloud2_merger" name="pointcloud_merger" namespace="/sensing/lidar">
            <param name="frame_id" value="base_link"/>
            <param name="input_topics" value="['/sensing/lidar/pointcloud2/rear', '/sensing/lidar/pointcloud2/right', '/sensing/lidar/pointcloud2/left']"/>
            <param name="frequency" value="40.0"/>
            <remap from="merged_pointcloud2" to="/sensing/lidar/pointcloud2/merged"/>
            <remap from="footprint" to="/common/footprint"/>
            <extra_arg name="use_intra_process_comms" value="true"/>
        </composable_node>
    </node_container>
</launch>