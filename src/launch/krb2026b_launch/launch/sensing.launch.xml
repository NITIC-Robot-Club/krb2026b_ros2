<?xml version="1.0"?>
<launch>
    <node name="lakibeam_front" pkg="lakibeam1" exec="lakibeam1_scan_node" output="screen" namespace="/sensing/lidar">
        <remap from="front" to="/sensing/lidar/laserscan/front" />
        <param from="$(find-pkg-share krb2026b_launch)/config/lidar_front.yaml"/>
    </node>
    <node name="lakibeam_rear" pkg="lakibeam1" exec="lakibeam1_scan_node" output="screen" namespace="/sensing/lidar">
        <remap from="rear" to="/sensing/lidar/laserscan/rear" />
        <param from="$(find-pkg-share krb2026b_launch)/config/lidar_rear.yaml"/>
    </node>
</launch>